# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rrconversationassist
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rrconversationassist
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# MinIO/S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=recordings
S3_REGION=us-east-1
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Discord Bot
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_random_secret_string_here_min_32_chars

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Web Application
WEB_BASE_URL=http://localhost:3000
WEB_PORT=3000

# Bot
BOT_PORT=3001

# Environment
NODE_ENV=development
LOG_LEVEL=debug

# Optional: WEEEK Integration
WEEEK_API_KEY=your_weeek_api_key_here
WEEEK_API_URL=https://api.weeek.net

# Optional: Webhook Integration
WEBHOOK_SECRET=your_webhook_secret_for_hmac_here
